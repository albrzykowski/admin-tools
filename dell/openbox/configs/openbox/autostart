#!/usr/bin/env bash

LOG_FILE="$HOME/.cache/openbox-autostart.log"
mkdir -p "$HOME/.cache"

log() {
  echo "[autostart] $*" >> "$LOG_FILE"
}

run_if_exists() {
  cmd="$1"
  shift

  if command -v "$cmd" >/dev/null 2>&1; then
    log "starting $cmd $*"
    "$cmd" "$@" >>"$LOG_FILE" 2>&1 &
  else
    log "missing: $cmd"
  fi
}

wait_for() {
  service="$1"
  timeout="${2:-10}"

  for i in $(seq 1 "$timeout"); do
    if pgrep -x "$service" >/dev/null; then
      log "$service ready"
      return 0
    fi
    sleep 1
  done

  log "timeout waiting for $service"
}

log "=== openbox session start ==="

run_if_exists nitrogen --restore

run_if_exists nm-applet

run_if_exists /usr/lib/policykit-1-gnome/polkit-gnome-authentication-agent-1

wait_for NetworkManager 5

run_if_exists picom --config ~/.config/picom/picom.conf

run_if_exists tint2

run_if_exists volumeicon

run_if_exists pcmanfm --desktop

log "=== autostart done ==="
