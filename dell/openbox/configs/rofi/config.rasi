configuration {
  modi: "drun,run,window";
  show-icons: true;
  drun-display-format: "{name}";
  font: "Sans 11";
  terminal: "lxterminal";
}

window {
  transparency: "real";
  background-color: #1e1e1e;
  border: 0;
  width: 40%;
}

listview {
  lines: 8;
  spacing: 4;
}

element {
  padding: 8px;
  border-radius: 4px;
}

element selected {
  background-color: #3a3a3a;
}
