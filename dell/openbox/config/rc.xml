<?xml version="1.0" encoding="UTF-8"?>
<openbox_config xmlns="http://openbox.org/3.4/rc" xmlns:xi="http://www.w3.org/2001/XInclude">
  <!-- RESISTANCE -->
  <resistance>
    <strength>30</strength>
    <screen_edge_strength>20</screen_edge_strength>
  </resistance>
  <!-- FOCUS -->
  <focus>
    <focusNew>yes</focusNew>
    <followMouse>no</followMouse>
    <focusLast>no</focusLast>
    <focusDelay>200</focusDelay>
    <underMouse>yes</underMouse>
    <raiseOnFocus>yes</raiseOnFocus>
  </focus>
  <!-- Placement -->
  <placement>
    <policy>Smart</policy>
    <center>no</center>
    <monitor>Mouse</monitor>
    <primaryMonitor>1</primaryMonitor>
  </placement>
  <!-- THEME AND FONTS -->
  <theme>
    <name>Nordic-Openbox</name>
    <titleLayout>NLDISMC</titleLayout>
    <keepBorder>yes</keepBorder>
    <animateIconify>no</animateIconify>
    <!-- FONTS -->
    <font place="ActiveWindow">
      <name>Fira Sans</name>
      <size>12</size>
      <weight>bold</weight>
      <slant>normal</slant>
    </font>
    <font place="InactiveWindow">
      <name>Fira Sans</name>
      <size>12</size>
      <weight>bold</weight>
      <slant>normal</slant>
    </font>
    <font place="MenuHeader">
      <name>Ubuntu Mono</name>
      <size>18</size>
      <weight>bold</weight>
      <slant>normal</slant>
    </font>
    <font place="MenuItem">
      <name>Ubuntu Mono</name>
      <size>18</size>
      <weight>normal</weight>
      <slant>normal</slant>
    </font>
    <font place="ActiveOnScreenDisplay">
      <name>Fira Sans</name>
      <size>18</size>
      <weight>bold</weight>
      <slant>normal</slant>
    </font>
    <font place="InactiveOnScreenDisplay">
      <name>Fira Sans</name>
      <size>18</size>
      <weight>normal</weight>
      <slant>normal</slant>
    </font>
  </theme>
  <!-- DESKTOPS -->
  <desktops>
    <number>4</number>
    <firstdesk>1</firstdesk>
    <popupTime>0</popupTime>
    <names>
      <name>1</name>
      <name>2</name>
      <name>3</name>
      <name>4</name>
    </names>
  </desktops>
  <!-- DESKTOP MARGINS -->
  <!-- reserve a portion of your screen where windows will not cover when
  they are maximized, or when they are initially placed. Many programs
  reserve space automatically, but you can use this in other cases. -->
  <margins>
    <top>0</top>
    <bottom>0</bottom>
    <left>0</left>
    <right>0</right>
  </margins>
  <!-- RESIZE/MOVE -->
  <resize>
    <drawContents>yes</drawContents>
    <popupShow>Nonpixel</popupShow>
    <popupPosition>Center</popupPosition>
    <popupFixedPosition>
      <x>10</x>
      <y>10</y>
    </popupFixedPosition>
  </resize>
  <!-- DOCK -->
  <dock>
    <!-- (Top|Bottom)(Left|Right|)|Top|Bottom|Left|Right|Floating -->
    <position>TopLeft</position>
    <floatingX>0</floatingX>
    <floatingY>0</floatingY>
    <noStrut>no</noStrut>
    <!-- 'Above', 'Normal', or 'Below' -->
    <stacking>Above</stacking>
    <!-- 'Vertical' or 'Horizontal' -->
    <direction>Vertical</direction>
    <autoHide>no</autoHide>
    <!-- in milliseconds (1000 = 1 second) -->
    <hideDelay>300</hideDelay>
    <showDelay>300</showDelay>
    <!-- 'Left', 'Middle', 'Right' -->
    <moveButton>Middle</moveButton>
  </dock>
  <!-- KEYBOARD SHORTCUTS -->
  <keyboard>
    <chainQuitKey>C-g</chainQuitKey>
    <!-- KEYBOARD / SWITCH DESKTOPS -->
    <keybind key="W-F1">
      <action name="GoToDesktop">
        <to>1</to>
      </action>
    </keybind>
    <keybind key="W-F2">
      <action name="GoToDesktop">
        <to>2</to>
      </action>
    </keybind>
    <keybind key="W-F3">
      <action name="GoToDesktop">
        <to>3</to>
      </action>
    </keybind>
    <keybind key="W-F4">
      <action name="GoToDesktop">
        <to>4</to>
      </action>
    </keybind>
    <!-- KEYBOARD / SHOW DESKTOP -->
    <keybind key="S-W-d">
      <action name="ToggleShowDesktop"/>
    </keybind>
    <!-- KEYBOARD / SEND WINDOW TO DESKTOP -->
    <keybind key="S-W-F1">
      <action name="SendToDesktop">
        <to>1</to>
        <follow>yes</follow>
      </action>
    </keybind>
    <keybind key="S-W-F2">
      <action name="SendToDesktop">
        <to>2</to>
        <follow>yes</follow>
      </action>
    </keybind>
    <keybind key="S-W-F3">
      <action name="SendToDesktop">
        <to>3</to>
        <follow>yes</follow>
      </action>
    </keybind>
    <keybind key="S-W-F4">
      <action name="SendToDesktop">
        <to>4</to>
        <follow>yes</follow>
      </action>
    </keybind>
    <!-- KEYBOARD / SEND WINDOW TO NEXT DISPLAY -->
    <keybind key="S-W-n">
      <action name="MoveResizeTo">
        <monitor>next</monitor>
      </action>
    </keybind>
    <!-- KEYBOARD / WINDOW SWITCHING -->
    <keybind key="A-Tab">
      <action name="NextWindow">
        <allDesktops>no</allDesktops>
        <finalactions>
          <action name="Focus"/>
          <action name="Raise"/>
          <action name="Unshade"/>
        </finalactions>
      </action>
    </keybind>
    <keybind key="A-S-Tab">
      <action name="PreviousWindow">
        <allDesktops>no</allDesktops>
        <finalactions>
          <action name="Focus"/>
          <action name="Raise"/>
          <action name="Unshade"/>
        </finalactions>
      </action>
    </keybind>
    <keybind key="W-Tab">
      <action name="NextWindow">
        <allDesktops>yes</allDesktops>
        <finalactions>
          <action name="Focus"/>
          <action name="Raise"/>
          <action name="Unshade"/>
        </finalactions>
      </action>
    </keybind>
    <keybind key="S-W-Tab">
      <action name="PreviousWindow">
        <allDesktops>yes</allDesktops>
        <finalactions>
          <action name="Focus"/>
          <action name="Raise"/>
          <action name="Unshade"/>
        </finalactions>
      </action>
    </keybind>
    <!-- KEYBOARD / WINDOW TILING -->
    <keybind key="W-Left">
      <action name="UnmaximizeFull"/>
      <action name="MoveResizeTo">
        <x>0</x>
        <y>0</y>
        <width>50%</width>
        <height>100%</height>
      </action>
    </keybind>
    <keybind key="W-Right">
      <action name="UnmaximizeFull"/>
      <action name="MoveResizeTo">
        <x>1/2</x>
        <y>0</y>
        <width>50%</width>
        <height>100%</height>
      </action>
    </keybind>
    <!-- KEYBOARD / MAXIMIZE WINDOW -->
    <keybind key="W-m">
      <action name="ToggleMaximize"/>
    </keybind>
    <!-- KEYBOARD / WINDOW BAR -->
    <keybind key="W-d">
      <action name="ToggleDecorations"/>
    </keybind>
    <!-- KEYBOARD / CLOSE WINDOW -->
    <keybind key="C-A-q">
      <action name="Close"/>
    </keybind>
    <!-- KEYBOARD / CLIENT MENU -->
    <keybind key="A-space">
      <action name="ShowMenu">
        <menu>client-menu</menu>
      </action>
    </keybind>
    <!-- KEYBOARD / ROOT MENU -->
    <keybind key="W-space">
      <action name="ShowMenu">
        <menu>root-menu</menu>
      </action>
    </keybind>
    <!-- KEYBOARD / WINDOW MENU -->
    <keybind key="S-W-space">
      <action name="ShowMenu">
        <menu>client-list-combined-menu</menu>
      </action>
    </keybind>
    <!-- KEYBOARD / APPLICATION MENU -->
    <keybind key="W-Return">
      <action name="Execute">
        <command>rofi -monitor primary -show run</command>
      </action>
    </keybind>
    <!-- KEYBOARD / SCREENSHOT -->
    <!-- Window -->
    <keybind key="Print">
      <action name="Execute">
        <command>scrot -u '%Y-%m-%dT%H%M%S.png' -e 'mv $f ~/image/screenshot &amp; viewnior ~/image/screenshot/$f'</command>
      </action>
    </keybind>
    <!-- Desktop -->
    <keybind key="W-Print">
      <action name="Execute">
        <command>scrot '%Y-%m-%dT%H%M%S.png' -e 'mv $f ~/image/screenshot &amp; viewnior ~/image/screenshot/$f'</command>
      </action>
    </keybind>
    <!-- KEYBOARD / VOLUME -->
    <!-- Volume up -->
    <!--<keybind key="W-F3">
      <action name="Execute">
        <command>mixer vol=+5%</command>
      </action>
    </keybind> -->
    <!-- Volume down -->
    <!-- <keybind key="W-F2">
      <action name="Execute">
        <command>mixer vol=-5%</command>
    </action>
    </keybind> -->
    <!-- Toggle volume mute -->
    <!-- <keybind key="W-F1">
      <action name="Execute">
        <command>mixer vol.mute=toggle</command>
      </action>
    </keybind> -->
    <!-- Toggle mic mute -->
    <!-- <<keybind key="W-F4">
      <action name="Execute">
        <command>mixer rec.mute=toggle</command>
      </action>
    </keybind> -->
    <!-- KEYBOARD / BACKLIGHT -->
    <!-- Brightness up -->
    <!-- <keybind key="W-F6">
      <action name="Execute">
        <command>backlight incr</command>
      </action>
    </keybind> -->
    <!-- Brightness down -->
    <!-- <keybind key="W-F5">
      <action name="Execute">
        <command>backlight decr</command>
      </action>
    </keybind> -->
    <!-- KEYBOARD / LOCK -->
    <keybind key="S-W-l">
      <action name="Execute">
        <command>~/bin/x11_lock.sh</command>
      </action>
    </keybind>
    <!-- KEYBOARD / SUSPEND -->
    <keybind key="S-W-z">
      <action name="Execute">
        <command>~/bin/x11_lock_suspend.sh</command>
      </action>
    </keybind>
    <!-- KEYBOARD / EXIT -->
    <keybind key="S-W-Escape">
      <action name="Exit">
        <prompt>no</prompt>
      </action>
    </keybind>
  </keyboard>
  <!-- MOUSE SETTINGS -->
  <mouse>
    <!-- MOUSE GENERAL SETTINGS -->
    <dragThreshold>1</dragThreshold>
    <doubleClickTime>200</doubleClickTime>
    <screenEdgeWarpTime>200</screenEdgeWarpTime>
    <screenEdgeWarpMouse>false</screenEdgeWarpMouse>
    <!-- MOUSE / FRAME / CONTEXT -->
    <context name="Frame">
      <!-- MOUSE / FRAME / CLICK TO UNSHADE -->
      <mousebind button="A-Left" action="Click">
        <action name="Unshade"/>
      </mousebind>
      <!-- MOUSE / FRAME / MOVE -->
      <mousebind button="A-Left" action="Drag">
        <action name="Move"/>
      </mousebind>
      <!-- MOUSE / FRAME/ RESIZE -->
      <mousebind button="A-Right" action="Drag">
        <action name="Resize"/>
      </mousebind>
    </context>
    <!-- MOUSE / TITLEBAR / CONTEXT -->
    <context name="Titlebar">
      <!-- MOUSE / TITLEBAR / MOVE -->
      <mousebind button="Left" action="Drag">
        <action name="Move"/>
      </mousebind>
    </context>
    <!-- MOUSE / TITLEBAR + CORNERS / CONTEXT -->
    <context name="Titlebar Top Right Bottom Left TLCorner TRCorner BRCorner BLCorner">
      <mousebind button="Left" action="Press">
        <action name="Focus"/>
        <action name="Raise"/>
        <action name="Unshade"/>
      </mousebind>
      <mousebind button="Middle" action="Press">
        <action name="Lower"/>
        <action name="FocusToBottom"/>
        <action name="Unfocus"/>
      </mousebind>
      <mousebind button="Right" action="Press">
        <action name="Focus"/>
        <action name="Raise"/>
        <action name="ShowMenu">
          <menu>client-menu</menu>
        </action>
      </mousebind>
    </context>
    <!-- MOUSE / TOP / CONTEXT -->
    <context name="Top">
      <mousebind button="Left" action="Drag">
        <action name="Resize">
          <edge>top</edge>
        </action>
      </mousebind>
    </context>
    <!-- MOUSE / LEFT / CONTEXT -->
    <context name="Left">
      <mousebind button="Left" action="Drag">
        <action name="Resize">
          <edge>left</edge>
        </action>
      </mousebind>
    </context>
    <!-- MOUSE / RIGHT / CONTEXT -->
    <context name="Right">
      <mousebind button="Left" action="Drag">
        <action name="Resize">
          <edge>right</edge>
        </action>
      </mousebind>
    </context>
    <!-- MOUSE / BOTTOM / CONTEXT -->
    <context name="Bottom">
      <mousebind button="Left" action="Drag">
        <action name="Resize">
          <edge>bottom</edge>
        </action>
      </mousebind>
      <mousebind button="Right" action="Press">
        <action name="Focus"/>
        <action name="Raise"/>
        <action name="ShowMenu">
          <menu>client-menu</menu>
        </action>
      </mousebind>
    </context>
    <!-- MOUSE / CORNERS / CONTEXT -->
    <context name="TRCorner BRCorner TLCorner BLCorner">
      <mousebind button="Left" action="Press">
        <action name="Focus"/>
        <action name="Raise"/>
        <action name="Unshade"/>
      </mousebind>
      <mousebind button="Left" action="Drag">
        <action name="Resize"/>
      </mousebind>
    </context>
    <!-- MOUSE / CLIENT / CONTEXT -->
    <context name="Client">
      <mousebind button="Left" action="Press">
        <action name="Focus"/>
        <action name="Raise"/>
      </mousebind>
      <mousebind button="Middle" action="Press">
        <action name="Focus"/>
        <action name="Raise"/>
      </mousebind>
      <mousebind button="Right" action="Press">
        <action name="Focus"/>
        <action name="Raise"/>
      </mousebind>
    </context>
    <!-- MOUSE / ICON / CONTEXT -->
    <context name="Icon">
      <mousebind button="Left" action="Press">
        <action name="Focus"/>
        <action name="Raise"/>
        <action name="Unshade"/>
        <action name="ShowMenu">
          <menu>client-menu</menu>
        </action>
      </mousebind>
      <mousebind button="Right" action="Press">
        <action name="Focus"/>
        <action name="Raise"/>
        <action name="ShowMenu">
          <menu>client-menu</menu>
        </action>
      </mousebind>
    </context>
    <!-- MOUSE / ALLDESKTOPS / CONTEXT -->
    <context name="AllDesktops">
      <mousebind button="Left" action="Press">
        <action name="Focus"/>
        <action name="Raise"/>
        <action name="Unshade"/>
      </mousebind>
      <mousebind button="Left" action="Click">
        <action name="ToggleOmnipresent"/>
      </mousebind>
    </context>
    <!-- MOUSE / SHADE / CONTEXT -->
    <context name="Shade">
      <mousebind button="Left" action="Press">
        <action name="Focus"/>
        <action name="Raise"/>
      </mousebind>
      <mousebind button="Left" action="Click">
        <action name="ToggleShade"/>
      </mousebind>
    </context>
    <!-- MOUSE / ICONIFY / CONTEXT -->
    <context name="Iconify">
      <mousebind button="Left" action="Press">
        <action name="Focus"/>
        <action name="Raise"/>
      </mousebind>
      <mousebind button="Left" action="Click">
        <action name="Iconify"/>
      </mousebind>
    </context>
    <!-- MOUSE / MAXIMIZE / CONTEXT -->
    <context name="Maximize">
      <mousebind button="Left" action="Press">
        <action name="Focus"/>
        <action name="Raise"/>
        <action name="Unshade"/>
      </mousebind>
      <mousebind button="Middle" action="Press">
        <action name="Focus"/>
        <action name="Raise"/>
        <action name="Unshade"/>
      </mousebind>
      <mousebind button="Right" action="Press">
        <action name="Focus"/>
        <action name="Raise"/>
        <action name="Unshade"/>
      </mousebind>
      <mousebind button="Left" action="Click">
        <action name="ToggleMaximize"/>
      </mousebind>
      <mousebind button="Middle" action="Click">
        <action name="ToggleMaximize">
          <direction>vertical</direction>
        </action>
      </mousebind>
      <mousebind button="Right" action="Click">
        <action name="ToggleMaximize">
          <direction>horizontal</direction>
        </action>
      </mousebind>
    </context>
    <!-- MOUSE / CLOSE / CONTEXT -->
    <context name="Close">
      <mousebind button="Left" action="Press">
        <action name="Focus"/>
        <action name="Raise"/>
        <action name="Unshade"/>
      </mousebind>
      <mousebind button="Left" action="Click">
        <action name="Close"/>
      </mousebind>
    </context>
    <!-- MOUSE / DESKTOP / CONTEXT -->
    <context name="Desktop">
      <mousebind button="Up" action="Click">
        <action name="GoToDesktop">
          <to>previous</to>
        </action>
      </mousebind>
      <mousebind button="Down" action="Click">
        <action name="GoToDesktop">
          <to>next</to>
        </action>
      </mousebind>
      <mousebind button="A-Up" action="Click">
        <action name="GoToDesktop">
          <to>previous</to>
        </action>
      </mousebind>
      <mousebind button="A-Down" action="Click">
        <action name="GoToDesktop">
          <to>next</to>
        </action>
      </mousebind>
      <mousebind button="C-A-Up" action="Click">
        <action name="GoToDesktop">
          <to>previous</to>
        </action>
      </mousebind>
      <mousebind button="C-A-Down" action="Click">
        <action name="GoToDesktop">
          <to>next</to>
        </action>
      </mousebind>
      <mousebind button="Left" action="Press">
        <action name="Focus"/>
        <action name="Raise"/>
      </mousebind>
      <mousebind button="Right" action="Press">
        <action name="Focus"/>
        <action name="Raise"/>
      </mousebind>
    </context>
    <!-- MOUSE / ROOT / CONTEXT -->
    <context name="Root">
      <mousebind button="Middle" action="Press">
        <action name="ShowMenu">
          <menu>client-list-combined-menu</menu>
        </action>
      </mousebind>
      <mousebind button="Right" action="Press">
        <action name="ShowMenu">
          <menu>root-menu</menu>
        </action>
      </mousebind>
    </context>
    <!-- MOUSE / MOVERESIZE / CONTEXT -->
    <context name="MoveResize">
      <mousebind button="Up" action="Click">
        <action name="GoToDesktop">
          <to>previous</to>
        </action>
      </mousebind>
      <mousebind button="Down" action="Click">
        <action name="GoToDesktop">
          <to>next</to>
        </action>
      </mousebind>
      <mousebind button="A-Up" action="Click">
        <action name="GoToDesktop">
          <to>previous</to>
        </action>
      </mousebind>
      <mousebind button="A-Down" action="Click">
        <action name="GoToDesktop">
          <to>next</to>
        </action>
      </mousebind>
    </context>
  </mouse>
  <!-- MENU SETTINGS -->
  <menu>
    <file>menu.xml</file>
    <showIcons>yes</showIcons>
    <hideDelay>100</hideDelay>
    <middle>no</middle>
    <submenuShowDelay>100</submenuShowDelay>
    <submenuHideDelay>100</submenuHideDelay>
    <manageDesktops>no</manageDesktops>
  </menu>
  <!-- APPLICATION SETTINGS -->
  <applications>
    <!-- Default to matching all normal windows (exclude dialog windows and
      panels) and maximize + remove window decoration when launched. -->
    <!-- <application type="normal">
      <maximized>true</maximized>
      <decor>no</decor>
    </application>
    <application class="vlc">
      <maximized>false</maximized>
      <decor>yes</decor>
    </application>
    <application name="viewnior">
      <maximized>false</maximized>
      <decor>yes</decor>
    </application>
    <application name="transmission-gtk">
      <maximized>false</maximized>
      <decor>yes</decor>
      <desktop>4</desktop>
    </application> -->
    <application class="UXTerm">
      <maximized>true</maximized>
      <decor>no</decor>
    </application>
    <application name="roxterm">
      <maximized>true</maximized>
      <decor>no</decor>
    </application>
  </applications>
</openbox_config>

